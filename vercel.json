{
  "version": 2,
  "builds": [
    {
      "src": "app.py",
      "use": "@vercel/python"
    },
    {
      "src": "external_inventory_app.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/tickets(.*)",
      "dest": "external_inventory_app.py"
    },
    {
      "src": "/web(.*)",
      "dest": "external_inventory_app.py"
    },
    {
      "src": "/(.*)",
      "dest": "app.py"
    }
  ]
}
